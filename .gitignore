# Python
__pycache__/
*.py[cod]
*$py.class
*.env
.env

# Data and Results
activations/
activations_v2/
persona_vectors/
persona_vectors_v2/
steering_results/
localization_output/
localization_v2/
ood_results/
eval_results/
eval_results_v2/
