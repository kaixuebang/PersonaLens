# Except for tiny representative examples if needed
!cross_model_results/*.png
!cross_model_results/*.json

# Keep PDF and images in paper
!paper/*.png
!paper/*.pdf

# IDEs
.idea/
.vscode/

# Ignore the review stuff
reviewer.txt
_organize_project.py

# Generated outputs (v2 canonical)
activations/*
persona_vectors/*
localization/*
eval_results/*
