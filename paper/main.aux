\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Cosine similarity matrix between persona vectors} (mean-difference, projected into a shared common space at Layer 14 to prevent layer-misalignment biases) on Qwen3-0.6B. Big Five traits (top-left block) are near-orthogonal. Defense mechanisms (bottom-right) form correlated subspaces, with humor--projection showing the highest correlation ($\cos {=}0.66$).}}{7}{figure.caption.22}\protected@file@percent }
\newlabel{fig:orthogonality}{{3}{7}{\textbf {Cosine similarity matrix between persona vectors} (mean-difference, projected into a shared common space at Layer 14 to prevent layer-misalignment biases) on Qwen3-0.6B. Big Five traits (top-left block) are near-orthogonal. Defense mechanisms (bottom-right) form correlated subspaces, with humor--projection showing the highest correlation ($\cos {=}0.66$)}{figure.caption.22}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Causal Primacy of User-Token Attention in Early Layers}{7}{subsection.5.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Token-Localized and Component Causal Importance for Openness}. \emph  {Left:} Replacing user-prompt tokens causally matters exactly as much as full-layer replacement, heavily dominating (KL $\approx 5.7$) in Layers 0--1, while replacing system-prompt tokens does almost nothing (KL $\approx 0.0001$). \emph  {Right:} Attention mechanism substitutions cause massive divergence shifts (KL $> 1.0$), whereas patching MLP outputs has zero effect in the primary encoding layers.}}{8}{figure.caption.23}\protected@file@percent }
\newlabel{fig:causal}{{4}{8}{\textbf {Token-Localized and Component Causal Importance for Openness}. \emph {Left:} Replacing user-prompt tokens causally matters exactly as much as full-layer replacement, heavily dominating (KL $\approx 5.7$) in Layers 0--1, while replacing system-prompt tokens does almost nothing (KL $\approx 0.0001$). \emph {Right:} Attention mechanism substitutions cause massive divergence shifts (KL $> 1.0$), whereas patching MLP outputs has zero effect in the primary encoding layers}{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Quantitative inference-time steering and collateral degradation trade-off.} As the injected persona vector magnitude ($\alpha $) increases, the structural personality shift achieves its intended target up to an optimal bound ($\alpha {\approx }2.0$ to $4.0$). Beyond this, we observe a classical inverted-U saturation pattern: the target keyword score drops and sequence perplexity explodes, representing orthogonal capability degradation and loss of linguistic coherence.}}{8}{figure.caption.24}\protected@file@percent }
\newlabel{fig:sweep}{{5}{8}{\textbf {Quantitative inference-time steering and collateral degradation trade-off.} As the injected persona vector magnitude ($\alpha $) increases, the structural personality shift achieves its intended target up to an optimal bound ($\alpha {\approx }2.0$ to $4.0$). Beyond this, we observe a classical inverted-U saturation pattern: the target keyword score drops and sequence perplexity explodes, representing orthogonal capability degradation and loss of linguistic coherence}{figure.caption.24}{}}
