\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces \textbf  {$\alpha $-sweep performance comparison across steering intensities.} Optimal steering occurs at $\alpha =5.0$, achieving maximum output length (1,205 chars), high keyword count (9 total), and best human evaluation score (4.6/5.0). Higher intensities ($\alpha =8.0$) reduce output quality despite maintaining keyword density, demonstrating non-monotonic steering dynamics.}}{15}{figure.caption.40}\protected@file@percent }
\newlabel{fig:alpha_sweep}{{9}{15}{\textbf {$\alpha $-sweep performance comparison across steering intensities.} Optimal steering occurs at $\alpha =5.0$, achieving maximum output length (1,205 chars), high keyword count (9 total), and best human evaluation score (4.6/5.0). Higher intensities ($\alpha =8.0$) reduce output quality despite maintaining keyword density, demonstrating non-monotonic steering dynamics}{figure.caption.40}{}}
