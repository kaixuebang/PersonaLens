\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {BFI-44 dose-response curves for all five Big Five traits.} Extraversion and Neuroticism show strong steering effects (ranges: 0.29-0.31), Openness shows moderate response (0.11), while Agreeableness exhibits minimal sensitivity (0.05). Conscientiousness shows reversed steering (higher scores at negative $\alpha $). Optimal steering occurs at $\alpha \in [+4, +6]$ before saturation effects emerge.}}{18}{figure.caption.55}\protected@file@percent }
\newlabel{fig:bfi_dose_response}{{8}{18}{\textbf {BFI-44 dose-response curves for all five Big Five traits.} Extraversion and Neuroticism show strong steering effects (ranges: 0.29-0.31), Openness shows moderate response (0.11), while Agreeableness exhibits minimal sensitivity (0.05). Conscientiousness shows reversed steering (higher scores at negative $\alpha $). Optimal steering occurs at $\alpha \in [+4, +6]$ before saturation effects emerge}{figure.caption.55}{}}
