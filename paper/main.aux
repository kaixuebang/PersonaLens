\@writefile{lof}{\contentsline {figure}{\numberline {24}{\ignorespaces \textbf  {Defense mechanism cosine similarity matrix (Qwen2.5-0.5B).} The full 9$\times $9 matrix shows hierarchical clustering mirroring Vaillant's maturity levels: immature defenses (projection, denial, regression, reaction formation) cluster strongly ($|\cos |=0.511$), neurotic defenses (rationalization, intellectualization, displacement) moderately ($0.189$), and mature defenses (humor, sublimation) are near-orthogonal ($0.030$).}}{27}{figure.caption.77}\protected@file@percent }
\newlabel{fig:defense_full}{{24}{27}{\textbf {Defense mechanism cosine similarity matrix (Qwen2.5-0.5B).} The full 9$\times $9 matrix shows hierarchical clustering mirroring Vaillant's maturity levels: immature defenses (projection, denial, regression, reaction formation) cluster strongly ($|\cos |=0.511$), neurotic defenses (rationalization, intellectualization, displacement) moderately ($0.189$), and mature defenses (humor, sublimation) are near-orthogonal ($0.030$)}{figure.caption.77}{}}
\@writefile{toc}{\contentsline {section}{\numberline {I}Multi-Framework Analysis: MBTI and Jungian Cognitive Functions}{27}{appendix.I}\protected@file@percent }
\newlabel{app:multiframework}{{I}{27}{Multi-Framework Analysis: MBTI and Jungian Cognitive Functions}{appendix.I}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {I.1}Cross-Framework Comparison: Cohen's d by Trait and Model}{28}{subsection.I.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {25}{\ignorespaces \textbf  {Cross-model Cohen's d for all three frameworks.} Each panel shows per-trait effect sizes across the five tested models. Big Five traits (left) show the strongest and most consistent signal; MBTI dimensions (center) show weaker signal with the E/I dimension notably inverted in Qwen2.5; Jungian functions (right) show intermediate signal with high within-framework variance.}}{28}{figure.caption.78}\protected@file@percent }
\newlabel{fig:cross_framework_comparison}{{25}{28}{\textbf {Cross-model Cohen's d for all three frameworks.} Each panel shows per-trait effect sizes across the five tested models. Big Five traits (left) show the strongest and most consistent signal; MBTI dimensions (center) show weaker signal with the E/I dimension notably inverted in Qwen2.5; Jungian functions (right) show intermediate signal with high within-framework variance}{figure.caption.78}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {I.2}Framework Best-Layer Distribution}{28}{subsection.I.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {26}{\ignorespaces \textbf  {Distribution of optimal layer position by framework.} Each point represents one (model, trait) pair. Jungian cognitive functions (green) peak significantly earlier in the network (median $\approx 0.35$) compared to Big Five (median $\approx 0.50$) or MBTI (median $\approx 0.50$), consistent with the hypothesis that cognitive function representations are encoded as more primitive processing features rather than high-level trait constructs.}}{28}{figure.caption.79}\protected@file@percent }
\newlabel{fig:framework_layer_dist}{{26}{28}{\textbf {Distribution of optimal layer position by framework.} Each point represents one (model, trait) pair. Jungian cognitive functions (green) peak significantly earlier in the network (median $\approx 0.35$) compared to Big Five (median $\approx 0.50$) or MBTI (median $\approx 0.50$), consistent with the hypothesis that cognitive function representations are encoded as more primitive processing features rather than high-level trait constructs}{figure.caption.79}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {I.3}Jungian Cognitive Functions: Layer-wise Heatmap}{29}{subsection.I.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {27}{\ignorespaces \textbf  {Jungian cognitive function layer-wise Cohen's d heatmap (Qwen3-0.6B).} Rows are the eight cognitive functions; columns are normalized layer positions (0 = first layer, 1 = final layer). Color encodes Cohen's d (green = strong positive signal, red = negative). Stars (\textbf  {$\star $}) mark each function's peak layer. Key patterns: (1) Ti and Fi (introverted judgment) peak in the earliest layers (L0--L4, normalized 0.00--0.14); (2) Te and Fe (extraverted judgment) peak in the middle layers (L13--L14, normalized 0.46--0.50); (3) Ne and Se (extraverted perceiving) peak early (normalized 0.07--0.14); (4) Ni (introverted intuition) uniquely peaks at the penultimate layer (normalized 0.96).}}{29}{figure.caption.80}\protected@file@percent }
\newlabel{fig:jungian_heatmap}{{27}{29}{\textbf {Jungian cognitive function layer-wise Cohen's d heatmap (Qwen3-0.6B).} Rows are the eight cognitive functions; columns are normalized layer positions (0 = first layer, 1 = final layer). Color encodes Cohen's d (green = strong positive signal, red = negative). Stars (\textbf {$\star $}) mark each function's peak layer. Key patterns: (1) Ti and Fi (introverted judgment) peak in the earliest layers (L0--L4, normalized 0.00--0.14); (2) Te and Fe (extraverted judgment) peak in the middle layers (L13--L14, normalized 0.46--0.50); (3) Ne and Se (extraverted perceiving) peak early (normalized 0.07--0.14); (4) Ni (introverted intuition) uniquely peaks at the penultimate layer (normalized 0.96)}{figure.caption.80}{}}
