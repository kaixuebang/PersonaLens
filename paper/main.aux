\newlabel{tab:perturbation_ratio}{{1}{6}{\textbf {Perturbation ratios across ten models.} RMS scale (hidden state magnitude at steering layer), perturbation ratio at $\alpha =6$, and mean steering effectiveness ($\Delta $) across 5 Big Five traits. Higher RMS = smaller effective perturbation = weaker steering at fixed $\alpha $}{table.caption.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Per-trait perturbation ratio vs.\ steering effectiveness.} Each point is one (model, trait) pair ($n{=}50$). The positive correlation ($r{=}0.59$, $p{<}0.0001$) confirms that perturbation ratio predicts steering effectiveness at fixed $\alpha $. PERSONA's exact model (LLaMA-3-8B, marked with $\dagger $) shows strong steering consistent with its moderate PR.}}{6}{figure.caption.19}\protected@file@percent }
\newlabel{fig:pr_scatter}{{2}{6}{\textbf {Per-trait perturbation ratio vs.\ steering effectiveness.} Each point is one (model, trait) pair ($n{=}50$). The positive correlation ($r{=}0.59$, $p{<}0.0001$) confirms that perturbation ratio predicts steering effectiveness at fixed $\alpha $. PERSONA's exact model (LLaMA-3-8B, marked with $\dagger $) shows strong steering consistent with its moderate PR}{figure.caption.19}{}}
