\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Position-swap control experiment.} Causal influence is concentrated at sequence-final positions regardless of content placement, revealing a positional component to activation patching. Both conditions show identical early-layer dominance (L0--L2), confirming attention-mediated persona propagation.}}{11}{figure.caption.30}\protected@file@percent }
\newlabel{fig:position_swap}{{6}{11}{\textbf {Position-swap control experiment.} Causal influence is concentrated at sequence-final positions regardless of content placement, revealing a positional component to activation patching. Both conditions show identical early-layer dominance (L0--L2), confirming attention-mediated persona propagation}{figure.caption.30}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \textbf  {Cross-model OOD generalization.} Mean cosine similarity between persona vectors extracted from disjoint scenario subsets. Larger models (Llama-3.2, Gemma-2) consistently exceed 0.90 across all traits, indicating robust trait abstractions. Smaller models show trait-dependent variability, with openness generalizing strongly but extraversion and agreeableness showing moderate stability.}}{11}{table.caption.31}\protected@file@percent }
\newlabel{tab:ood}{{5}{11}{\textbf {Cross-model OOD generalization.} Mean cosine similarity between persona vectors extracted from disjoint scenario subsets. Larger models (Llama-3.2, Gemma-2) consistently exceed 0.90 across all traits, indicating robust trait abstractions. Smaller models show trait-dependent variability, with openness generalizing strongly but extraversion and agreeableness showing moderate stability}{table.caption.31}{}}
