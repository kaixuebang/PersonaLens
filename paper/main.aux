\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Cross-model persona vector orthogonality.} Side-by-side cosine similarity matrices at each model's middle layer (Qwen3-0.6B at L14; Qwen2.5-0.5B at L12; TinyLlama-1.1B at L11). All models show near-orthogonal Big Five vectors and correlated defense mechanism subspaces, with mean off-diagonal $|\cos |$ of 0.171, 0.194, and 0.125 respectively.}}{9}{figure.caption.25}\protected@file@percent }
\newlabel{fig:cross_model_ortho}{{6}{9}{\textbf {Cross-model persona vector orthogonality.} Side-by-side cosine similarity matrices at each model's middle layer (Qwen3-0.6B at L14; Qwen2.5-0.5B at L12; TinyLlama-1.1B at L11). All models show near-orthogonal Big Five vectors and correlated defense mechanism subspaces, with mean off-diagonal $|\cos |$ of 0.171, 0.194, and 0.125 respectively}{figure.caption.25}{}}
