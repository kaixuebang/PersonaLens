\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Cross-model encoding profiles for Openness} (normalized layer axis $\ell /L$ enables direct comparison across architectures with different layer counts). Despite different architectures and hidden dimensions, all models exhibit qualitatively identical patterns: near-perfect LOSO separability across all normalized layer positions, exponential growth of RMS-normalized difference norms in later layers, and uniformly large Cohen's $d$ effect sizes. \textbf  {Notice the universal exponential growth of the RMS-normalized difference norm across all architectures}: norms grow by $5\text  {--}20\times $ from layer~0 to the final layers, confirming that personality information is continuously amplified with depth even after an early plateau in linear separability.}}{16}{figure.caption.48}\protected@file@percent }
\newlabel{fig:cross_model_profile}{{7}{16}{\textbf {Cross-model encoding profiles for Openness} (normalized layer axis $\ell /L$ enables direct comparison across architectures with different layer counts). Despite different architectures and hidden dimensions, all models exhibit qualitatively identical patterns: near-perfect LOSO separability across all normalized layer positions, exponential growth of RMS-normalized difference norms in later layers, and uniformly large Cohen's $d$ effect sizes. \textbf {Notice the universal exponential growth of the RMS-normalized difference norm across all architectures}: norms grow by $5\text {--}20\times $ from layer~0 to the final layers, confirming that personality information is continuously amplified with depth even after an early plateau in linear separability}{figure.caption.48}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces \textbf  {Paraphrase control results with confidence intervals.} Cross-template probe accuracy demonstrates that personality detection is robust to prompt wording, ruling out keyword confounding; 95\% Wilson confidence intervals quantify uncertainty under the small-sample setting.}}{16}{table.caption.49}\protected@file@percent }
\newlabel{tab:paraphrase}{{7}{16}{\textbf {Paraphrase control results with confidence intervals.} Cross-template probe accuracy demonstrates that personality detection is robust to prompt wording, ruling out keyword confounding; 95\% Wilson confidence intervals quantify uncertainty under the small-sample setting}{table.caption.49}{}}
