\@writefile{toc}{\contentsline {section}{\numberline {14}Multi-Framework Analysis: MBTI and Jungian Cognitive Functions}{30}{section.14}\protected@file@percent }
\newlabel{app:multiframework}{{14}{30}{Multi-Framework Analysis: MBTI and Jungian Cognitive Functions}{section.14}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {14.1}Cross-Framework Comparison: Cohen's d by Trait and Model}{31}{subsection.14.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {24}{\ignorespaces \textbf  {Cross-model Cohen's d for all three frameworks.} Each panel shows per-trait effect sizes across the five tested models. Big Five traits (left) show the strongest and most consistent signal; MBTI dimensions (center) show weaker signal with the E/I dimension notably inverted in Qwen2.5; Jungian functions (right) show intermediate signal with high within-framework variance. Note the absence of a monotonic model-size effect in the Jungian panel.}}{31}{figure.caption.77}\protected@file@percent }
\newlabel{fig:cross_framework_comparison}{{24}{31}{\textbf {Cross-model Cohen's d for all three frameworks.} Each panel shows per-trait effect sizes across the five tested models. Big Five traits (left) show the strongest and most consistent signal; MBTI dimensions (center) show weaker signal with the E/I dimension notably inverted in Qwen2.5; Jungian functions (right) show intermediate signal with high within-framework variance. Note the absence of a monotonic model-size effect in the Jungian panel}{figure.caption.77}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {14.2}Framework Best-Layer Distribution}{31}{subsection.14.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {25}{\ignorespaces \textbf  {Distribution of optimal layer position by framework.} Each point represents one (model, trait) pair. Jungian cognitive functions (green) peak significantly earlier in the network (median $\approx 0.35$) compared to Big Five (median $\approx 0.50$) or MBTI (median $\approx 0.50$), consistent with the hypothesis that cognitive function representations are encoded as more primitive processing features rather than high-level trait constructs.}}{31}{figure.caption.78}\protected@file@percent }
\newlabel{fig:framework_layer_dist}{{25}{31}{\textbf {Distribution of optimal layer position by framework.} Each point represents one (model, trait) pair. Jungian cognitive functions (green) peak significantly earlier in the network (median $\approx 0.35$) compared to Big Five (median $\approx 0.50$) or MBTI (median $\approx 0.50$), consistent with the hypothesis that cognitive function representations are encoded as more primitive processing features rather than high-level trait constructs}{figure.caption.78}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {14.3}MBTI E/I Inversion Anomaly}{32}{subsection.14.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {26}{\ignorespaces \textbf  {Big Five Extraversion vs.\spacefactor \@m {} MBTI E/I: same construct, different encoding.} Left: Big Five Extraversion shows positive Cohen's d across all layers and all five models---the direction is universally consistent. Right: MBTI E/I shows dramatically different behavior. Qwen2.5-0.5B (red) exhibits \emph  {negative} d across nearly all 24 layers, indicating a systematic sign inversion relative to the MBTI labeling convention. Other models maintain positive d but with substantially weaker signal (2--5$\times $ weaker than Big Five). This architecture-specific inversion demonstrates that the same psychological axis can be encoded with different orientations depending on how the construct is described in prompts.}}{32}{figure.caption.79}\protected@file@percent }
\newlabel{fig:mbti_inversion}{{26}{32}{\textbf {Big Five Extraversion vs.\@ MBTI E/I: same construct, different encoding.} Left: Big Five Extraversion shows positive Cohen's d across all layers and all five models---the direction is universally consistent. Right: MBTI E/I shows dramatically different behavior. Qwen2.5-0.5B (red) exhibits \emph {negative} d across nearly all 24 layers, indicating a systematic sign inversion relative to the MBTI labeling convention. Other models maintain positive d but with substantially weaker signal (2--5$\times $ weaker than Big Five). This architecture-specific inversion demonstrates that the same psychological axis can be encoded with different orientations depending on how the construct is described in prompts}{figure.caption.79}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {14.4}Jungian Cognitive Functions: Layer-wise Heatmap}{33}{subsection.14.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {27}{\ignorespaces \textbf  {Jungian cognitive function layer-wise Cohen's d heatmap (Qwen3-0.6B).} Rows are the eight cognitive functions; columns are normalized layer positions (0 = first layer, 1 = final layer). Color encodes Cohen's d (green = strong positive signal, red = negative). Stars (\textbf  {$\star $}) mark each function's peak layer. Key patterns: (1) Ti and Fi (introverted judgment) peak in the earliest layers (L0--L4, normalized 0.00--0.14), reflecting primitive value-consistency processing; (2) Te and Fe (extraverted judgment) peak in the middle layers (L13--L14, normalized 0.46--0.50), reflecting more abstract social-organizational processing; (3) Ne and Se (extraverted perceiving) peak early (normalized 0.07--0.14), consistent with direct environmental engagement; (4) Ni (introverted intuition) uniquely peaks at the penultimate layer (normalized 0.96), suggesting that convergent long-range pattern recognition requires near-maximal network depth.}}{33}{figure.caption.80}\protected@file@percent }
\newlabel{fig:jungian_heatmap}{{27}{33}{\textbf {Jungian cognitive function layer-wise Cohen's d heatmap (Qwen3-0.6B).} Rows are the eight cognitive functions; columns are normalized layer positions (0 = first layer, 1 = final layer). Color encodes Cohen's d (green = strong positive signal, red = negative). Stars (\textbf {$\star $}) mark each function's peak layer. Key patterns: (1) Ti and Fi (introverted judgment) peak in the earliest layers (L0--L4, normalized 0.00--0.14), reflecting primitive value-consistency processing; (2) Te and Fe (extraverted judgment) peak in the middle layers (L13--L14, normalized 0.46--0.50), reflecting more abstract social-organizational processing; (3) Ne and Se (extraverted perceiving) peak early (normalized 0.07--0.14), consistent with direct environmental engagement; (4) Ni (introverted intuition) uniquely peaks at the penultimate layer (normalized 0.96), suggesting that convergent long-range pattern recognition requires near-maximal network depth}{figure.caption.80}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {14.5}MBTI Layer Profiles by Model}{34}{subsection.14.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {28}{\ignorespaces \textbf  {Qwen3-0.6B: MBTI dimension layer profiles.} Each subplot shows Cohen's d (solid) and LOSO accuracy (dashed) across normalized layer depth for one MBTI dimension. The E/I dimension shows strong positive signal peaking at late layers; S/N and T/F show moderate signal; J/P shows the weakest and most variable signal.}}{34}{figure.caption.81}\protected@file@percent }
\newlabel{fig:qwen3_mbti}{{28}{34}{\textbf {Qwen3-0.6B: MBTI dimension layer profiles.} Each subplot shows Cohen's d (solid) and LOSO accuracy (dashed) across normalized layer depth for one MBTI dimension. The E/I dimension shows strong positive signal peaking at late layers; S/N and T/F show moderate signal; J/P shows the weakest and most variable signal}{figure.caption.81}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {29}{\ignorespaces \textbf  {Qwen2.5-0.5B: MBTI dimension layer profiles.} The E/I subplot shows negative or near-zero d across all layers---the inversion anomaly documented in the Multi-Framework Analysis. J/P maintains positive signal despite global instability in the MBTI dimensions.}}{35}{figure.caption.82}\protected@file@percent }
\newlabel{fig:qwen25_mbti}{{29}{35}{\textbf {Qwen2.5-0.5B: MBTI dimension layer profiles.} The E/I subplot shows negative or near-zero d across all layers---the inversion anomaly documented in the Multi-Framework Analysis. J/P maintains positive signal despite global instability in the MBTI dimensions}{figure.caption.82}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {30}{\ignorespaces \textbf  {TinyLlama-1.1B: MBTI dimension layer profiles.} J/P shows sign instability (negative layers in early-to-mid network), consistent with the LLaMA-family J/P instability noted in the main text.}}{36}{figure.caption.83}\protected@file@percent }
\newlabel{fig:tinyllama_mbti}{{30}{36}{\textbf {TinyLlama-1.1B: MBTI dimension layer profiles.} J/P shows sign instability (negative layers in early-to-mid network), consistent with the LLaMA-family J/P instability noted in the main text}{figure.caption.83}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {31}{\ignorespaces \textbf  {Llama-3.2-1B: MBTI dimension layer profiles.} Similar to TinyLlama, J/P shows early-layer sign instability (4 of 16 layers negative). The T/F dimension is the strongest signal for this model.}}{37}{figure.caption.84}\protected@file@percent }
\newlabel{fig:llama32_mbti}{{31}{37}{\textbf {Llama-3.2-1B: MBTI dimension layer profiles.} Similar to TinyLlama, J/P shows early-layer sign instability (4 of 16 layers negative). The T/F dimension is the strongest signal for this model}{figure.caption.84}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {32}{\ignorespaces \textbf  {Gemma-2-2B: MBTI dimension layer profiles.} All four MBTI dimensions show positive and stable signal. J/P achieves the strongest d among all models for this dimension (d=3.25 at best layer), consistent with Gemma-2's generally high representational capacity.}}{38}{figure.caption.85}\protected@file@percent }
\newlabel{fig:gemma2_mbti}{{32}{38}{\textbf {Gemma-2-2B: MBTI dimension layer profiles.} All four MBTI dimensions show positive and stable signal. J/P achieves the strongest d among all models for this dimension (d=3.25 at best layer), consistent with Gemma-2's generally high representational capacity}{figure.caption.85}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {14.6}Jungian Cognitive Function Layer Profiles by Model}{39}{subsection.14.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {33}{\ignorespaces \textbf  {Qwen3-0.6B: Jungian cognitive function layer profiles.} Ti and Fi peak sharply at the earliest layers (L0--L4); Te and Fe peak in middle layers; Ni uniquely peaks at the penultimate layer---the clearest demonstration of the cognitive depth architecture described in the Multi-Framework Analysis.}}{39}{figure.caption.86}\protected@file@percent }
\newlabel{fig:qwen3_jungian}{{33}{39}{\textbf {Qwen3-0.6B: Jungian cognitive function layer profiles.} Ti and Fi peak sharply at the earliest layers (L0--L4); Te and Fe peak in middle layers; Ni uniquely peaks at the penultimate layer---the clearest demonstration of the cognitive depth architecture described in the Multi-Framework Analysis}{figure.caption.86}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {34}{\ignorespaces \textbf  {Qwen2.5-0.5B: Jungian cognitive function layer profiles.} Ti achieves an exceptionally high d=6.88 at an early layer---the strongest single-function signal across all models and frameworks. Fe shows the weakest and most variable signal for this model.}}{40}{figure.caption.87}\protected@file@percent }
\newlabel{fig:qwen25_jungian}{{34}{40}{\textbf {Qwen2.5-0.5B: Jungian cognitive function layer profiles.} Ti achieves an exceptionally high d=6.88 at an early layer---the strongest single-function signal across all models and frameworks. Fe shows the weakest and most variable signal for this model}{figure.caption.87}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {35}{\ignorespaces \textbf  {TinyLlama-1.1B: Jungian cognitive function layer profiles.} Se achieves the highest peak d (4.25) for this model. The general early-layer dominance of introverted functions is less pronounced than in Qwen3, consistent with TinyLlama's lower representational capacity.}}{41}{figure.caption.88}\protected@file@percent }
\newlabel{fig:tinyllama_jungian}{{35}{41}{\textbf {TinyLlama-1.1B: Jungian cognitive function layer profiles.} Se achieves the highest peak d (4.25) for this model. The general early-layer dominance of introverted functions is less pronounced than in Qwen3, consistent with TinyLlama's lower representational capacity}{figure.caption.88}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {36}{\ignorespaces \textbf  {Llama-3.2-1B: Jungian cognitive function layer profiles.} Ni achieves the highest peak d (3.25) at a mid-to-late layer position, consistent with the cognitive depth hypothesis. Fe shows the most variable profile across layers for this model.}}{42}{figure.caption.89}\protected@file@percent }
\newlabel{fig:llama32_jungian}{{36}{42}{\textbf {Llama-3.2-1B: Jungian cognitive function layer profiles.} Ni achieves the highest peak d (3.25) at a mid-to-late layer position, consistent with the cognitive depth hypothesis. Fe shows the most variable profile across layers for this model}{figure.caption.89}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {37}{\ignorespaces \textbf  {Gemma-2-2B: Jungian cognitive function layer profiles.} The most uniform signal across all eight functions, with all functions achieving d$\ge $1.6. Ti and Si show relatively strong early-layer peaks; Fe and Se peak in middle layers. Gemma-2's consistently strong cross-framework performance suggests its training data contained rich and varied personality-related text.}}{43}{figure.caption.90}\protected@file@percent }
\newlabel{fig:gemma2_jungian}{{37}{43}{\textbf {Gemma-2-2B: Jungian cognitive function layer profiles.} The most uniform signal across all eight functions, with all functions achieving d$\ge $1.6. Ti and Si show relatively strong early-layer peaks; Fe and Se peak in middle layers. Gemma-2's consistently strong cross-framework performance suggests its training data contained rich and varied personality-related text}{figure.caption.90}{}}
