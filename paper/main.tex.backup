\subsection{MBTI E/I Inversion Anomaly}

\begin{figure}[H]
\centering
\includegraphics[width=\textwidth]{figures/mbti_vs_b5_extraversion.png}
\caption{\textbf{Big Five Extraversion vs.\@ MBTI E/I: same construct, different encoding.} Left: Big Five Extraversion shows positive Cohen's d across all layers and all five models---the direction is universally consistent. Right: MBTI E/I shows dramatically different behavior. Qwen2.5-0.5B (red) exhibits \emph{negative} d across nearly all 24 layers, indicating a systematic sign inversion relative to the MBTI labeling convention. Other models maintain positive d but with substantially weaker signal (2--5$\times$ weaker than Big Five). This architecture-specific inversion demonstrates that the same psychological axis can be encoded with different orientations depending on how the construct is described in prompts.}
\label{fig:mbti_inversion}
\end{figure}

\subsection{Jungian Cognitive Functions: Layer-wise Heatmap}

\begin{figure}[H]
\centering
\includegraphics[width=\textwidth]{figures/jungian_layer_heatmap.png}
\caption{\textbf{Jungian cognitive function layer-wise Cohen's d heatmap (Qwen3-0.6B).} Rows are the eight cognitive functions; columns are normalized layer positions (0 = first layer, 1 = final layer). Color encodes Cohen's d (green = strong positive signal, red = negative). Stars (\textbf{$\star$}) mark each function's peak layer. Key patterns: (1) Ti and Fi (introverted judgment) peak in the earliest layers (L0--L4, normalized 0.00--0.14), reflecting primitive value-consistency processing; (2) Te and Fe (extraverted judgment) peak in the middle layers (L13--L14, normalized 0.46--0.50), reflecting more abstract social-organizational processing; (3) Ne and Se (extraverted perceiving) peak early (normalized 0.07--0.14), consistent with direct environmental engagement; (4) Ni (introverted intuition) uniquely peaks at the penultimate layer (normalized 0.96), suggesting that convergent long-range pattern recognition requires near-maximal network depth.}
\label{fig:jungian_heatmap}
\end{figure}

